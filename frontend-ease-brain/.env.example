# Frontend environment example for EaseBrain
# Place values in a .env (for local dev) or configure build-time env vars in your host.

# Vite exposes variables starting with VITE_ to the client.
# Set this to your backend API base URL (example: https://api.your-domain.com/api)
# For production, this should point to your deployed backend API
VITE_BASE_URL=http://www.easebrain.live/api

# Optional: any API keys or public-only secrets
VITE_API_KEY=your_api_key_here