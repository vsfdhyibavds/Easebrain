# ============================================================================
# EaseBrain Frontend Environment Configuration
# ============================================================================
# Copy this file to .env.local or .env and adjust for your environment

# ============================================================================
# API Configuration
# ============================================================================
# Base URL for API calls
# Local development: http://localhost:5500/api or http://127.0.0.1:5500/api
# Production: https://easebrain-backend.onrender.com/api
VITE_BASE_URL=http://localhost:5500/api

# ============================================================================
# Application Environment
# ============================================================================
NODE_ENV=development

# ============================================================================
# Debug Configuration
# ============================================================================
# Enable verbose logging in development
VITE_DEBUG=false

# ============================================================================
# Notes
# ============================================================================
# 1. This file is loaded by Vite during build time
# 2. All variables must be prefixed with VITE_ to be exposed to the client
# 3. React Query and other runtime configs are set in src/api/client.js
# 4. For production, ensure VITE_BASE_URL points to the API backend
# 5. Never commit sensitive data to .env files - use Render dashboard for secrets