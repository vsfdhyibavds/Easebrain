# EaseBrain Render Deployment Configuration
# This is a template for environment variables needed for Render deployment
# Copy and update these values in your Render dashboard under Environment Variables

# =============== FLASK CONFIGURATION ===============
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=0

# =============== DATABASE CONFIGURATION ===============
# This is automatically set by Render from the database service
# DATABASE_URL=postgresql://user:password@host:port/dbname

# =============== SECRET KEYS (MUST BE SET) ===============
# Generate these with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this
JWT_SECRET_KEY=your-jwt-secret-key-here-change-this

# =============== EMAIL CONFIGURATION (SendGrid) ===============
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDER_EMAIL=noreply@easebrain.live
# Optional: Specify data residency for GDPR compliance
SENDGRID_DATA_RESIDENCY=

# =============== FRONTEND CONFIGURATION ===============
# URLs for email verification and redirects
FRONTEND_URL=https://www.easebrain.live
VERIFY_BASE_URL=https://www.easebrain.live

# =============== JWT CONFIGURATION ===============
JWT_ACCESS_TOKEN_EXPIRES=86400  # 24 hours in seconds
JWT_TOKEN_LOCATION=headers
JWT_HEADER_NAME=Authorization
JWT_HEADER_TYPE=Bearer
JWT_COOKIE_SECURE=true
JWT_COOKIE_CSRF_PROTECT=true

# =============== CORS CONFIGURATION ===============
# CORS is configured in app.py, but frontend URL can be added via CORS_ORIGINS
# CORS_ORIGINS=https://www.easebrain.live,https://example.com

# =============== DATABASE CONFIGURATION ===============
SQLALCHEMY_TRACK_MODIFICATIONS=false

# =============== GUNICORN CONFIGURATION ===============
# Number of worker processes (Render auto-scales these)
# 2-4 for standard plans, adjust based on plan type
WEB_CONCURRENCY=4

# =============== OPTIONAL: LLM INTEGRATION ===============
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-if-using-llm

# =============== LOGGING & MONITORING ===============
LOG_LEVEL=info
# Enable audit logging for security events
AUDIT_LOGGING_ENABLED=true

# =============== SECURITY ===============
# Enable CSRF protection
CSRF_ENABLED=true
# Session security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
PERMANENT_SESSION_LIFETIME=86400

# =============== PORT (Usually handled by Render) ===============
# PORT=5000  # Render sets this automatically

# =============== OPTIONAL FEATURES ===============
# Mock email mode for testing (set to 'true' to use mock emails instead of SendGrid)
MOCK_EMAIL_MODE=false
# Allow unverified sender email (development only)
ALLOW_UNVERIFIED_SENDER=false
